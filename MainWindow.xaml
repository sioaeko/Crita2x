                                <Slider x:Name="HueShiftSlider"
                                        Minimum="-180"
                                        Maximum="180"
                                        Value="0"
                                        TickFrequency="15"
                                        ValueChanged="HslSlider_ValueChanged" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="채도 보정" Style="{StaticResource ToolLabel}" />
                                    <TextBlock x:Name="HslSaturationText"
                                               Grid.Column="1"
                                               Text="0"
                                               Style="{StaticResource ToolLabel}" />
                                </Grid>
                                <Slider x:Name="HslSaturationSlider"
                                        Minimum="-100"
                                        Maximum="100"
                                        Value="0"
                                        ValueChanged="HslSlider_ValueChanged" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="명도 보정" Style="{StaticResource ToolLabel}" />
                                    <TextBlock x:Name="HslLightnessText"
                                               Grid.Column="1"
                                               Text="0"
                                               Style="{StaticResource ToolLabel}" />
                                </Grid>
                                <Slider x:Name="HslLightnessSlider"
                                        Minimum="-100"
                                        Maximum="100"
                                        Value="0"
                                        ValueChanged="HslSlider_ValueChanged" />
                                <UniformGrid Columns="2" Margin="0,8,0,0">
                                    <Button Click="ApplyHsl_Click" Margin="0,0,6,8">HSL 적용</Button>
                                    <Button Click="ResetHsl_Click" Margin="6,0,0,8">초기화</Button>
                                </UniformGrid>

                                <TextBlock Text="레벨" Style="{StaticResource SectionTitle}" />
                                <Border x:Name="HistogramHost"
                                        Height="74"
                                        Background="#101012"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        ClipToBounds="True"
                                        SizeChanged="HistogramHost_SizeChanged">
                                    <Grid Margin="8">
                                        <Path x:Name="HistogramPath"
                                              Fill="#3349B9B0"
                                              Stroke="{StaticResource AccentBrush}"
                                              StrokeThickness="1"
                                              Stretch="Fill" />
                                    </Grid>
                                </Border>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="입력 블랙 / 화이트" Style="{StaticResource ToolLabel}" />
                                    <TextBlock x:Name="LevelsInputText"
                                               Grid.Column="1"
                                               Text="0 - 255"
                                               Style="{StaticResource ToolLabel}" />
                                </Grid>
                                <Slider x:Name="LevelsBlackSlider" Minimum="0" Maximum="254" Value="0" ValueChanged="LevelsSlider_ValueChanged" />
                                <Slider x:Name="LevelsWhiteSlider" Minimum="1" Maximum="255" Value="255" ValueChanged="LevelsSlider_ValueChanged" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="중간톤 감마" Style="{StaticResource ToolLabel}" />
                                    <TextBlock x:Name="LevelsGammaText"
                                               Grid.Column="1"
                                               Text="1.00"
                                               Style="{StaticResource ToolLabel}" />
                                </Grid>
                                <Slider x:Name="LevelsGammaSlider" Minimum="0.1" Maximum="3" Value="1" TickFrequency="0.1" ValueChanged="LevelsSlider_ValueChanged" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="출력 블랙 / 화이트" Style="{StaticResource ToolLabel}" />
                                    <TextBlock x:Name="LevelsOutputText"
                                               Grid.Column="1"
                                               Text="0 - 255"
                                               Style="{StaticResource ToolLabel}" />
                                </Grid>
                                <Slider x:Name="LevelsOutputBlackSlider" Minimum="0" Maximum="254" Value="0" ValueChanged="LevelsSlider_ValueChanged" />
                                <Slider x:Name="LevelsOutputWhiteSlider" Minimum="1" Maximum="255" Value="255" ValueChanged="LevelsSlider_ValueChanged" />

                                <UniformGrid Columns="3" Margin="0,8,0,8">
                                    <Button Click="ApplyLevels_Click" Margin="0,0,4,0">적용</Button>
                                    <Button Click="AutoLevels_Click" Margin="4,0,4,0">자동</Button>
                                    <Button Click="ResetLevels_Click" Margin="4,0,0,0">초기화</Button>
                                </UniformGrid>
                                <Button Click="ResetEdits_Click" Margin="0,0,0,8">원본으로 되돌리기</Button>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="레이어">
                        <DockPanel Margin="16">
                            <Border DockPanel.Dock="Top"
                                    Background="#101214"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="레이어" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock x:Name="LayerSummaryText"
                                                   Text="열린 이미지 없음"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,5,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource IconButton}"
                                                Click="AddBlankLayer_Click"
                                                Margin="0,0,6,0"
                                                ToolTip="빈 레이어 추가">
                                            <TextBlock Text="&#xE710;" Style="{StaticResource IconOnlyGlyph}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}"
                                                Click="DuplicateLayer_Click"
                                                Margin="0,0,6,0"
                                                ToolTip="선택 레이어 복제">
                                            <TextBlock Text="&#xE8C8;" Style="{StaticResource IconOnlyGlyph}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}"
                                                Click="DeleteLayer_Click"
                                                ToolTip="선택 레이어 삭제">
                                            <TextBlock Text="&#xE74D;" Style="{StaticResource IconOnlyGlyph}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                                <TextBlock Text="이름" Style="{StaticResource ToolLabel}" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="72" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LayerNameBox"
                                             IsEnabled="False" />
                                    <Button Grid.Column="1"
                                            Click="RenameLayer_Click"
                                            Margin="8,0,0,0">적용</Button>
                                </Grid>

                                <TextBlock Text="혼합" Style="{StaticResource ToolLabel}" Margin="0,0,0,4" />
                                <ComboBox x:Name="LayerBlendModeBox"
                                          SelectedIndex="0"
                                          IsEnabled="False"
                                          SelectionChanged="LayerBlendModeBox_SelectionChanged"
                                          Margin="0,0,0,8">
                                    <ComboBoxItem Content="일반" Tag="Normal" />
                                    <ComboBoxItem Content="곱하기" Tag="Multiply" />
                                    <ComboBoxItem Content="스크린" Tag="Screen" />
                                    <ComboBoxItem Content="오버레이" Tag="Overlay" />
                                    <ComboBoxItem Content="어둡게" Tag="Darken" />
                                    <ComboBoxItem Content="밝게" Tag="Lighten" />
                                </ComboBox>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="불투명도" Style="{StaticResource ToolLabel}" Margin="0,0,0,4" />
                                    <TextBlock x:Name="LayerOpacityText"
                                               Grid.Column="1"
                                               Text="100%"
                                               Style="{StaticResource ToolLabel}"
                                               Margin="0,0,0,4" />
                                </Grid>
                                <Slider x:Name="LayerOpacitySlider"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="100"
                                        IsEnabled="False"
                                        ValueChanged="LayerOpacitySlider_ValueChanged"
                                        PreviewMouseLeftButtonDown="LayerOpacitySlider_MouseDown"
                                        PreviewMouseLeftButtonUp="LayerOpacitySlider_MouseUp" />
                                <CheckBox x:Name="LayerLockBox"
                                          Content="레이어 잠금"
                                          IsEnabled="False"
                                          Click="LayerLockBox_Click"
                                          Margin="0,8,0,0" />

                                <TextBlock Text="변형" Style="{StaticResource SectionTitle}" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="72" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LayerWidthBox"
                                             IsEnabled="False"
                                             Margin="0,0,6,0"
                                             ToolTip="레이어 너비" />
                                    <TextBox x:Name="LayerHeightBox"
                                             Grid.Column="1"
                                             IsEnabled="False"
                                             Margin="6,0,6,0"
                                             ToolTip="레이어 높이" />
                                    <Button Grid.Column="2"
                                            Click="ApplyLayerSize_Click">적용</Button>
                                </Grid>
                                <CheckBox x:Name="LayerAspectLockBox"
                                          Content="비율 고정"
                                          IsChecked="True"
                                          Margin="0,0,0,8" />
                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                    <Button Click="FitLayerToCanvas_Click" Margin="0,0,6,8">맞춤</Button>
                                    <Button Click="FillLayerToCanvas_Click" Margin="6,0,0,8">채우기</Button>
                                    <Button Click="RotateLayerLeft_Click" Margin="0,0,6,8">↺</Button>
                                    <Button Click="RotateLayerRight_Click" Margin="6,0,0,8">↻</Button>
                                    <Button Click="FlipLayerHorizontal_Click" Margin="0,0,6,0">좌우</Button>
                                    <Button Click="FlipLayerVertical_Click" Margin="6,0,0,0">상하</Button>
                                </UniformGrid>

                                <TextBlock Text="위치" Style="{StaticResource SectionTitle}" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="72" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LayerOffsetXBox"
                                             IsEnabled="False"
                                             Margin="0,0,6,0"
                                             ToolTip="레이어 X 위치" />
                                    <TextBox x:Name="LayerOffsetYBox"
                                             Grid.Column="1"
                                             IsEnabled="False"
                                             Margin="6,0,6,0"
                                             ToolTip="레이어 Y 위치" />
                                    <Button Grid.Column="2"
                                            Click="ApplyLayerPosition_Click">적용</Button>
                                </Grid>
                                <UniformGrid Columns="3" Margin="0,0,0,8">
                                    <Button x:Name="MoveLayerButton"
                                            Click="MoveLayerMode_Click"
                                            Margin="0,0,6,8">이동</Button>
                                    <Button Click="ResetLayerPosition_Click"
                                            Margin="3,0,3,8">원점</Button>
                                    <Button Click="CenterLayer_Click"
                                            Margin="6,0,0,8">중앙</Button>
                                    <Button Click="NudgeLayer_Click"
                                            Tag="left"
                                            Margin="0,0,6,0">←</Button>
                                    <Button Click="NudgeLayer_Click"
                                            Tag="up"
                                            Margin="3,0,3,0">↑</Button>
                                    <Button Click="NudgeLayer_Click"
                                            Tag="right"
                                            Margin="6,0,0,0">→</Button>
                                </UniformGrid>
                                <Button Click="NudgeLayer_Click"
                                        Tag="down"
                                        Margin="0,0,0,8">↓</Button>
                                <UniformGrid Columns="3" Margin="0,0,0,8">
                                    <Button Click="AlignLayer_Click"
                                            Tag="left"
                                            Margin="0,0,6,8">왼쪽</Button>
                                    <Button Click="AlignLayer_Click"
                                            Tag="center-x"
                                            Margin="3,0,3,8">가운데</Button>
                                    <Button Click="AlignLayer_Click"
                                            Tag="right"
                                            Margin="6,0,0,8">오른쪽</Button>
                                    <Button Click="AlignLayer_Click"
                                            Tag="top"
                                            Margin="0,0,6,0">위</Button>
                                    <Button Click="AlignLayer_Click"
                                            Tag="center-y"
                                            Margin="3,0,3,0">중앙</Button>
                                    <Button Click="AlignLayer_Click"
                                            Tag="bottom"
                                            Margin="6,0,0,0">아래</Button>
                                </UniformGrid>

                                <TextBlock Text="순서" Style="{StaticResource ToolLabel}" Margin="0,4,0,4" />
                                <UniformGrid Columns="4" Margin="0,0,0,8">
                                    <Button Click="SendLayerToBottom_Click"
                                            Margin="0,0,4,0"
                                            ToolTip="선택 레이어를 맨 아래로 보내기">⇩</Button>
                                    <Button Click="SendLayerBackward_Click"
                                            Margin="4,0,4,0"
                                            ToolTip="선택 레이어를 한 단계 뒤로 보내기">↓</Button>
                                    <Button Click="BringLayerForward_Click"
                                            Margin="4,0,4,0"
                                            ToolTip="선택 레이어를 한 단계 앞으로 가져오기">↑</Button>
                                    <Button Click="BringLayerToTop_Click"
                                            Margin="4,0,0,0"
                                            ToolTip="선택 레이어를 맨 위로 가져오기">⇧</Button>
                                </UniformGrid>

                                <Button Click="MergeVisibleLayers_Click"
                                        Margin="0,6,0,0">보이는 레이어 병합</Button>

                                <TextBlock Text="마스크" Style="{StaticResource ToolLabel}" Margin="0,14,0,4" />
                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                    <Button Click="AddLayerMask_Click" Margin="0,0,4,8">마스크 추가</Button>
                                    <Button Click="RemoveLayerMask_Click" Margin="4,0,0,8">마스크 삭제</Button>
                                    <Button Click="InvertLayerMask_Click" Margin="0,0,4,0">마스크 반전</Button>
                                    <Button x:Name="MaskHideButton" Click="MaskHideBrush_Click" Margin="4,0,0,0">숨김 브러시</Button>
                                </UniformGrid>
                                <Button x:Name="MaskRevealButton"
                                        Click="MaskRevealBrush_Click"
                                        Margin="0,0,0,8">복원 브러시</Button>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="마스크 브러시" Style="{StaticResource ToolLabel}" Margin="0,0,0,4" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ElementName=MaskBrushSizeSlider, Path=Value, StringFormat={}{0:F0}}"
                                               Style="{StaticResource ToolLabel}"
                                               Margin="0,0,0,4" />
                                </Grid>
                                <Slider x:Name="MaskBrushSizeSlider"
                                        Minimum="8"
                                        Maximum="220"
                                        Value="56" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="경도" Style="{StaticResource ToolLabel}" Margin="0,0,0,4" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ElementName=MaskBrushHardnessSlider, Path=Value, StringFormat={}{0:F0}}"
                                               Style="{StaticResource ToolLabel}"
                                               Margin="0,0,0,4" />
                                </Grid>
                                <Slider x:Name="MaskBrushHardnessSlider"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="62" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="강도" Style="{StaticResource ToolLabel}" Margin="0,0,0,4" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ElementName=MaskBrushStrengthSlider, Path=Value, StringFormat={}{0:F0}}"
                                               Style="{StaticResource ToolLabel}"
                                               Margin="0,0,0,4" />
                                </Grid>
                                <Slider x:Name="MaskBrushStrengthSlider"
                                        Minimum="5"
                                        Maximum="100"
                                        Value="85" />
                            </StackPanel>

                            <ListBox x:Name="LayerList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     SelectionChanged="LayerList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListBoxItem}">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,7" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                    <Border x:Name="Root"
                                                            Background="#17171B"
                                                            BorderBrush="#29282E"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#202025" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="#3C3A40" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#1D2C2A" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="11">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Click="LayerVisibility_Click"
                                                      PreviewMouseLeftButtonDown="LayerVisibility_MouseDown"
                                                      VerticalAlignment="Center"
                                                      ToolTip="레이어 표시" />
                                            <Border Grid.Column="1"
                                                    Width="42"
                                                    Height="42"
                                                    Background="#101012"
                                                    BorderBrush="{StaticResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    ClipToBounds="True"
                                                    VerticalAlignment="Top"
                                                    Margin="0,0,10,0">
                                                <Image Source="{Binding Bitmap}"
                                                       Stretch="Uniform" />
                                            </Border>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Detail}"
                                                           Style="{StaticResource MutedText}"
                                                           Margin="0,4,0,0"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding PositionText}"
                                                           Style="{StaticResource MutedText}"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding BlendModeText}"
                                                           Style="{StaticResource MutedText}"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding MaskText}"
                                                           Style="{StaticResource MutedText}"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding LockText}"
                                                           Style="{StaticResource MutedText}"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3"
                                                        VerticalAlignment="Center"
                                                        Margin="10,0,0,0">
                                                <TextBlock Text="{Binding OpacityText}"
                                                           Style="{StaticResource MutedText}"
                                                           TextAlignment="Right" />
                                                <CheckBox IsChecked="{Binding IsLocked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Click="LayerLock_Click"
                                                          PreviewMouseLeftButtonDown="LayerLock_MouseDown"
                                                          ToolTip="레이어 잠금"
                                                          HorizontalAlignment="Right"
                                                          Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="기록">
                        <DockPanel Margin="16">
                            <Border DockPanel.Dock="Top"
                                    Background="#101214"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="히스토리" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock x:Name="HistorySummaryText"
                                                   Text="열린 이미지 없음"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,5,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource IconButton}"
                                                Click="Undo_Click"
                                                Margin="0,0,6,0"
                                                ToolTip="실행 취소">
                                            <TextBlock Text="&#xE7A7;" Style="{StaticResource IconOnlyGlyph}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}"
                                                Click="Redo_Click"
                                                ToolTip="다시 실행">
                                            <TextBlock Text="&#xE7A6;" Style="{StaticResource IconOnlyGlyph}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock DockPanel.Dock="Bottom"
                                       Text="항목을 선택하면 해당 편집 시점으로 이동합니다."
                                       Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0" />

                            <ListBox x:Name="HistoryList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     SelectionChanged="HistoryList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListBoxItem}">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,7" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                    <Border x:Name="Root"
                                                            Background="#17171B"
                                                            BorderBrush="#29282E"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#202025" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="#3C3A40" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#1D2C2A" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="11">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="26"
                                                    Height="26"
                                                    Background="#101214"
                                                    BorderBrush="{StaticResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Step}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Label}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Detail}"
                                                           Style="{StaticResource MutedText}"
                                                           Margin="0,4,0,0"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="내보내기">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16">
                                <TextBlock Text="저장" FontSize="16" FontWeight="SemiBold" />
                                <Button Style="{StaticResource PrimaryButton}" Click="SaveCurrent_Click" Margin="0,14,0,10">현재 이미지 저장</Button>
                                <Button Click="OpenOutputFolder_Click" Margin="0,0,0,10">저장 폴더 열기</Button>
                                <Button Click="RemoveSelected_Click" Margin="0,0,0,10">선택 항목 제거</Button>

                                <TextBlock Text="현재 이미지" Style="{StaticResource SectionTitle}" />
                                <TextBlock x:Name="CurrentDetailText"
                                           Text="선택된 이미지 없음"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#09090A"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           Text="준비됨"
                           Foreground="{StaticResource MutedInkBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="LastOutputNameText"
                               Text="완료 결과 없음"
                               Style="{StaticResource MutedText}"
                               MaxWidth="260"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <Button x:Name="OpenLastOutputButton"
                            Style="{StaticResource StatusActionButton}"
                            Click="OpenLastOutput_Click"
                            IsEnabled="False"
                            Margin="0,0,6,0"
                            ToolTip="최근 완료 이미지를 미리보기에서 열기">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A7;" Style="{StaticResource ButtonIconGlyph}" />
                            <TextBlock Text="결과 보기" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RevealLastOutputButton"
                            Style="{StaticResource StatusActionButton}"
                            Click="RevealLastOutput_Click"
                            IsEnabled="False"
                            ToolTip="탐색기에서 최근 완료 파일 위치 열기">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" Style="{StaticResource ButtonIconGlyph}" />
                            <TextBlock Text="위치" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
