<Window x:Class="Waifu16K.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Crita2x"
        Width="1360"
        Height="860"
        MinWidth="1180"
        MinHeight="720"
        Background="{StaticResource ShellBrush}"
        Foreground="{StaticResource InkBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True"
        Drop="Window_Drop">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="72"
                            ResizeBorderThickness="8"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Margin" Value="0,20,0,9" />
        </Style>

        <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ToolLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>

        <Style x:Key="ButtonIconGlyph" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="IconOnlyGlyph" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource ButtonIconGlyph}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="EmptyStateGlyph" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="36" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="StatusActionButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#101012"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="138" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Crita2x" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="Upscale · Cutout · Clean" Style="{StaticResource MutedText}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource PrimaryButton}" Click="OpenImages_Click" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8E5;" Style="{StaticResource ButtonIconGlyph}" />
                            <TextBlock Text="이미지 추가" Foreground="#071311" />
                        </StackPanel>
                    </Button>
                    <Button Click="RunSelected_Click" Margin="0,0,8,0" ToolTip="선택 항목 업스케일">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" Style="{StaticResource ButtonIconGlyph}" />
                            <TextBlock Text="선택 실행" />
                        </StackPanel>
                    </Button>
                    <Button Click="RunQueue_Click" Margin="0,0,8,0" ToolTip="대기열 전체 업스케일">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B1;" Style="{StaticResource ButtonIconGlyph}" />
                            <TextBlock Text="전체 실행" />
                        </StackPanel>
                    </Button>
                    <Button Click="Cancel_Click" Margin="0,0,8,0" ToolTip="실행 중지">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71A;" Style="{StaticResource ButtonIconGlyph}" />
                            <TextBlock Text="중지" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ToolbarOpenLastOutputButton"
                            Click="OpenLastOutput_Click"
                            IsEnabled="False"
                            Margin="0,0,8,0"
                            ToolTip="최근 완료 이미지를 미리보기에서 열기">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A7;" Style="{StaticResource ButtonIconGlyph}" />
                            <TextBlock Text="결과 보기" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ToolbarRevealLastOutputButton"
                            Click="RevealLastOutput_Click"
                            IsEnabled="False"
                            Margin="0,0,8,0"
                            ToolTip="탐색기에서 최근 완료 파일 위치 열기">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" Style="{StaticResource ButtonIconGlyph}" />
                            <TextBlock Text="탐색기" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IconButton}"
                            Click="Undo_Click"
                            Margin="0,0,4,0"
                            ToolTip="실행 취소">
                        <TextBlock Text="&#xE7A7;" Style="{StaticResource IconOnlyGlyph}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}"
                            Click="Redo_Click"
                            ToolTip="다시 실행">
                        <TextBlock Text="&#xE7A6;" Style="{StaticResource IconOnlyGlyph}" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="엔진" Foreground="{StaticResource MutedInkBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="EnginePathBox" Width="300" Margin="0,0,8,0" LostFocus="EnginePathBox_LostFocus" />
                    <Button Style="{StaticResource IconButton}" Click="BrowseEngine_Click" ToolTip="Waifu2x 엔진 선택">
                        <TextBlock Text="&#xE8B7;" Style="{StaticResource IconOnlyGlyph}" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="3"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource CaptionButton}"
                            Click="Minimize_Click"
                            Margin="0,0,7,0"
                            ToolTip="최소화">
                        <Grid Width="12" Height="12">
                            <Rectangle Width="10"
                                       Height="1.5"
                                       RadiusX="0.75"
                                       RadiusY="0.75"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Grid>
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Style="{StaticResource CaptionButton}"
                            Click="MaximizeRestore_Click"
                            Margin="0,0,7,0"
                            ToolTip="최대화">
                        <Grid Width="12" Height="12">
                            <Rectangle x:Name="MaximizeGlyph"
                                       Width="9"
                                       Height="9"
                                       RadiusX="1.5"
                                       RadiusY="1.5"
                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       StrokeThickness="1.5" />
                        </Grid>
                    </Button>
                    <Button x:Name="CloseButton"
                            Style="{StaticResource CloseCaptionButton}"
                            Click="Close_Click"
                            ToolTip="닫기">
                        <Grid Width="12" Height="12">
                            <Line X1="3"
                                  Y1="3"
                                  X2="9"
                                  Y2="9"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                            <Line X1="9"
                                  Y1="3"
                                  X2="3"
                                  Y2="9"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="284" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="14">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="대기열" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock x:Name="QueueCountText" Text="0개 항목" Style="{StaticResource MutedText}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource IconButton}"
                                Click="ClearQueue_Click"
                                ToolTip="대기열 비우기">
                            <TextBlock Text="&#xE74D;" Style="{StaticResource IconOnlyGlyph}" />
                        </Button>
                    </Grid>

                    <ListBox x:Name="JobList"
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionChanged="JobList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="{x:Type ListBoxItem}">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,7" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                            <Border x:Name="Root"
                                                    Background="#19191D"
                                                    BorderBrush="#27262B"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="#202025" />
                                                    <Setter TargetName="Root" Property="BorderBrush" Value="#3C3A40" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="#1D2C2A" />
                                                    <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="11">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding FileName}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="SemiBold" />
                                        <Grid Grid.Row="1" Margin="0,5,0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Status}" Style="{StaticResource MutedText}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Progress, StringFormat={}{0}%}"
                                                       Style="{StaticResource MutedText}" />
                                        </Grid>
                                        <ProgressBar Grid.Row="2"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding Progress}" />
                                        <UniformGrid Grid.Row="3"
                                                     Columns="2"
                                                     Margin="0,9,0,0">
                                            <Button Click="OpenJobOutput_Click"
                                                    IsEnabled="{Binding HasOutput}"
                                                    Margin="0,0,4,0"
                                                    ToolTip="완료 이미지를 미리보기에서 열기">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8A7;" Style="{StaticResource ButtonIconGlyph}" />
                                                    <TextBlock Text="보기" />
                                                </StackPanel>
                                            </Button>
                                            <Button Click="RevealJobOutput_Click"
                                                    IsEnabled="{Binding HasOutput}"
                                                    Margin="4,0,0,0"
                                                    ToolTip="탐색기에서 완료 파일 위치 열기">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8B7;" Style="{StaticResource ButtonIconGlyph}" />
                                                    <TextBlock Text="위치" />
                                                </StackPanel>
                                            </Button>
                                        </UniformGrid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1" Background="#09090A">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="38" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="16"
                        CornerRadius="8"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Border.Background>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,32,32"
                                      ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#131316">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,32,32" />
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing Brush="#19191D">
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <RectangleGeometry Rect="0,0,16,16" />
                                                <RectangleGeometry Rect="16,16,16,16" />
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Border.Background>

                    <Grid x:Name="PreviewSurface"
                          AllowDrop="True"
                          Drop="Window_Drop">
                        <ScrollViewer x:Name="PreviewScroller"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="False"
                                      PreviewMouseWheel="Preview_MouseWheel">
                            <Grid x:Name="ImageHost"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  MouseLeftButtonDown="Preview_MouseLeftButtonDown"
                                  MouseMove="Preview_MouseMove"
                                  MouseLeftButtonUp="Preview_MouseLeftButtonUp"
                                  MouseLeave="Preview_MouseLeave">
                                <Grid.LayoutTransform>
                                    <ScaleTransform x:Name="PreviewScaleTransform" ScaleX="1" ScaleY="1" />
                                </Grid.LayoutTransform>
                                <Image x:Name="PreviewImage"
                                       Stretch="Fill"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <Image x:Name="CompareImage"
                                       Visibility="Collapsed"
                                       Stretch="Fill"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Clip>
                                        <RectangleGeometry x:Name="CompareClip" Rect="0,0,0,0" />
                                    </Image.Clip>
                                </Image>
                                <Canvas x:Name="CompareOverlay"
                                        Visibility="Collapsed"
                                        IsHitTestVisible="False">
                                    <Rectangle x:Name="CompareDivider"
                                               Width="2"
                                               Fill="{StaticResource AccentBrush}" />
                                    <Border x:Name="CompareBeforeBadge"
                                            Background="#D80B0B0D"
                                            BorderBrush="{StaticResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,4">
                                        <TextBlock Text="기준"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource InkBrush}" />
                                    </Border>
                                    <Border x:Name="CompareAfterBadge"
                                            Background="#D80B0B0D"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,4">
                                        <TextBlock Text="현재"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource InkBrush}" />
                                    </Border>
                                </Canvas>
                                <Canvas x:Name="OverlayCanvas"
                                        IsHitTestVisible="False">
                                    <Rectangle x:Name="GridOverlay"
                                               Visibility="Collapsed"
                                               IsHitTestVisible="False" />
                                    <Rectangle x:Name="ActiveLayerBounds"
                                               Visibility="Collapsed"
                                               Stroke="{StaticResource InkBrush}"
                                               StrokeThickness="1.5"
                                               StrokeDashArray="6 3"
                                               Fill="Transparent" />
                                    <Rectangle x:Name="ActiveLayerHandleTopLeft"
                                               Visibility="Collapsed"
                                               Width="8"
                                               Height="8"
                                               Fill="{StaticResource AccentBrush}" />
                                    <Rectangle x:Name="ActiveLayerHandleTopRight"
                                               Visibility="Collapsed"
                                               Width="8"
                                               Height="8"
                                               Fill="{StaticResource AccentBrush}" />
                                    <Rectangle x:Name="ActiveLayerHandleBottomLeft"
                                               Visibility="Collapsed"
                                               Width="8"
                                               Height="8"
                                               Fill="{StaticResource AccentBrush}" />
                                    <Rectangle x:Name="ActiveLayerHandleBottomRight"
                                               Visibility="Collapsed"
                                               Width="8"
                                               Height="8"
                                               Fill="{StaticResource AccentBrush}" />
                                    <Rectangle x:Name="CropRect"
                                               Visibility="Collapsed"
                                               Stroke="{StaticResource AccentBrush}"
                                               StrokeThickness="2"
                                               StrokeDashArray="5 3"
                                               Fill="#225EEAD4" />
                                    <Image x:Name="SelectionMaskOverlay"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"
                                           Stretch="Fill" />
                                    <Polyline x:Name="LassoPath"
                                              Visibility="Collapsed"
                                              Stroke="{StaticResource AccentBrush}"
                                              StrokeThickness="2"
                                              StrokeLineJoin="Round" />
                                    <Rectangle x:Name="SelectionRect"
                                               Visibility="Collapsed"
                                               Stroke="{StaticResource InkBrush}"
                                               StrokeThickness="1.5"
                                               StrokeDashArray="3 3"
                                               Fill="#1A82DCCF" />
                                    <Ellipse x:Name="BrushGhost"
                                             Visibility="Collapsed"
                                             Width="40"
                                             Height="40"
                                             Stroke="{StaticResource AccentWarmBrush}"
                                             StrokeThickness="2"
                                             Fill="#22FFB86B" />
                                    <Ellipse x:Name="CloneSourceMarker"
                                             Visibility="Collapsed"
                                             Width="22"
                                             Height="22"
                                             Stroke="{StaticResource AccentBrush}"
                                             StrokeThickness="2"
                                             Fill="#1A82DCCF"
                                             IsHitTestVisible="False" />
                                </Canvas>
                            </Grid>
                        </ScrollViewer>

                        <StackPanel x:Name="EmptyState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="360">
                            <TextBlock Text="&#xEB9F;" Style="{StaticResource EmptyStateGlyph}" />
                            <TextBlock Text="이미지를 끌어오거나 추가하세요"
                                       FontSize="23"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                            <TextBlock Text="PNG, JPG, WEBP, BMP, TIFF"
                                       Foreground="{StaticResource MutedInkBrush}"
                                       TextAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Background="#101012"
                      Margin="16,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CurrentFileText"
                               Text="준비됨"
                               Foreground="{StaticResource MutedInkBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Margin="12,0" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="8,0">
                        <CheckBox x:Name="GridOverlayBox"
                                  Content="격자"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Checked="GridOverlay_Changed"
                                  Unchecked="GridOverlay_Changed" />
                        <TextBox x:Name="GridSizeBox"
                                 Text="64"
                                 Width="48"
                                 Margin="0,0,10,0"
                                 ToolTip="격자 크기"
                                 LostFocus="GridSizeBox_LostFocus" />
                        <Button x:Name="CompareBaselineButton"
                                Click="SetCompareBaseline_Click"
                                ToolTip="현재 상태를 비교 기준으로 저장">기준</Button>
                        <Button x:Name="CompareToggleButton"
                                Click="CompareToggle_Click"
                                Margin="6,0,0,0"
                                ToolTip="기준과 현재 이미지 비교">비교</Button>
                        <Slider x:Name="CompareSlider"
                                Width="118"
                                Minimum="0"
                                Maximum="100"
                                Value="50"
                                IsEnabled="False"
                                ValueChanged="CompareSlider_ValueChanged"
                                Margin="10,0,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="8,0">
                        <Button Style="{StaticResource IconButton}"
                                Click="ZoomOut_Click"
                                ToolTip="축소">−</Button>
                        <TextBlock x:Name="ZoomText"
                                   Text="100%"
                                   Foreground="{StaticResource MutedInkBrush}"
                                   Width="54"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Button Style="{StaticResource IconButton}"
                                Click="ZoomIn_Click"
                                ToolTip="확대">+</Button>
                        <Button Click="ZoomActual_Click"
                                Margin="8,0,0,0"
                                ToolTip="100%">100%</Button>
                        <Button Click="ZoomFit_Click"
                                Margin="6,0,0,0"
                                ToolTip="화면에 맞춤">맞춤</Button>
                    </StackPanel>
                    <TextBlock x:Name="ImageInfoText"
                               Grid.Column="3"
                               Text=""
                               Foreground="{StaticResource MutedInkBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0" />
                </Grid>
            </Grid>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1,0,0,0">
                <TabControl x:Name="ToolTabs" BorderThickness="0" Margin="0">
                    <TabItem Header="Waifu2x">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16">
                                <TextBlock Text="업스케일" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="모델" Style="{StaticResource ToolLabel}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="40" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="ModelBox" SelectedIndex="0" SelectionChanged="ModelBox_SelectionChanged" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource IconButton}"
                                            Click="RefreshModels_Click"
                                            ToolTip="모델 새로고침"
                                            Margin="8,0,0,0">
                                        <TextBlock Text="&#xE72C;" Style="{StaticResource IconOnlyGlyph}" />
                                    </Button>
